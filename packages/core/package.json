{
  "name": "@workflow-eps/core",
  "version": "0.0.4",
  "description": "Zero-dependency TypeScript pipeline orchestration library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "vite": "6.4.3",
    "vite-node": "3.2.4",
    "vitest": "$vitest"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
